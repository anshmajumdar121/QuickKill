<Window x:Class="QuickKill.AttributionPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickKill"
        Width="320" Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Effect>
        <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270" Opacity="0.55" Color="#000000"/>
    </Window.Effect>

    <Border CornerRadius="14" BorderThickness="1">
        <Border.Background>
            <SolidColorBrush Color="#E81C1C1E"/>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#55FFFFFF" Offset="0"/>
                <GradientStop Color="#12FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <StackPanel Margin="22,20,22,20">
            <!-- Title row -->
            <Grid Margin="0,0,0,16">
                <TextBlock Text="Attribution Lock"
                           Foreground="#F5F5F7"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#8E8E93"
                        FontSize="12"
                        Cursor="Hand"
                        Click="CancelBtn_Click">✕</Button>
            </Grid>

            <!-- Password box -->
            <Border CornerRadius="10" BorderThickness="1" Padding="12,8" Margin="0,0,0,12">
                <Border.Background><SolidColorBrush Color="#22FFFFFF"/></Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#30FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <PasswordBox x:Name="PwdBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F5F5F7"
                             CaretBrush="#FF6A2B"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             PasswordChar="●"
                             KeyDown="PwdBox_KeyDown"/>
            </Border>

            <!-- Status -->
            <TextBlock x:Name="StatusLabel"
                       Text="Enter the developer password."
                       Foreground="#636366"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Margin="0,0,0,14"/>

            <!-- Confirm button -->
            <Button x:Name="ConfirmBtn"
                    Content="Verify"
                    Height="36"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    Cursor="Hand"
                    Click="ConfirmBtn_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#F54E00"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E04500"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</Window>
