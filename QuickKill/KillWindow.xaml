<Window x:Class="QuickKill.KillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickKill"
        Width="460" Height="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        Deactivated="Window_Deactivated">

    <Window.Resources>

        <!-- Thin glass scrollbar -->
        <Style x:Key="ThinScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent" Width="5">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Command="ScrollBar.PageUpCommand" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Command="ScrollBar.PageDownCommand" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#4DFFFFFF" CornerRadius="3" Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Title bar: normal buttons -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AEAEB2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontFamily="{TemplateBinding FontFamily}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#28FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Title bar: close button (red hover) -->
        <Style x:Key="TitleCloseBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AEAEB2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontFamily="{TemplateBinding FontFamily}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scroll arrow buttons (floating overlay on list) -->
        <Style x:Key="ScrollArrowBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="Foreground" Value="#AEAEB2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="7" BorderBrush="#28FFFFFF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#65FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Window.Effect>
        <DropShadowEffect BlurRadius="48" ShadowDepth="6" Direction="270"
                          Opacity="0.45" Color="#000000"/>
    </Window.Effect>

    <Grid x:Name="RootGrid">
        <!-- Layer 1: Dark glass base — WPF background so rounded corners stay clean -->
        <Border x:Name="GlassBase" CornerRadius="18" BorderThickness="1">
            <Border.Background>
                <SolidColorBrush Color="#CC1C1C1E"/>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                    <GradientStop Color="#14FFFFFF" Offset="0.35"/>
                    <GradientStop Color="#0DFFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <!-- Layer 2: Specular sheen (top glow, non-interactive) -->
        <Border VerticalAlignment="Top" Height="90" CornerRadius="18,18,0,0"
                IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1CFFFFFF" Offset="0"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Layer 3: Content (clipped to rounded corners) -->
        <Border CornerRadius="18" ClipToBounds="True" Background="Transparent">
            <DockPanel>

                <!-- Header — draggable -->
                <Border DockPanel.Dock="Top" Padding="20,10,6,10" Cursor="SizeAll"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Border.Background>
                        <SolidColorBrush Color="#00000000"/>
                    </Border.Background>
                    <Grid>
                        <!-- Left: title + count -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Kill Application"
                                       Foreground="#F5F5F7"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                            <Border x:Name="CountBadge"
                                    Background="#26FFFFFF"
                                    CornerRadius="9"
                                    Padding="8,2"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CountLabel"
                                           Foreground="#C7C7CC"
                                           FontFamily="Segoe UI"
                                           FontSize="11"/>
                            </Border>
                        </StackPanel>

                        <!-- Right: settings + window controls -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,-2,0">
                            <Button x:Name="SettingsBtn"
                                    Style="{StaticResource TitleBtn}"
                                    Click="SettingsBtn_Click"
                                    ToolTip="Display settings">
                                <TextBlock Text="⚙" FontSize="13"/>
                            </Button>
                            <!-- Thin separator -->
                            <Border Width="1" Height="14" Background="#22FFFFFF" Margin="3,0"/>
                            <Button Style="{StaticResource TitleBtn}"
                                    Click="MinimizeButton_Click" ToolTip="Minimise">
                                <TextBlock Text="&#x2212;" FontSize="13" Margin="0,2,0,0"/>
                            </Button>
                            <Button Style="{StaticResource TitleBtn}"
                                    Click="MaximizeButton_Click" ToolTip="Maximise">
                                <TextBlock Text="&#x25A1;" FontSize="11"/>
                            </Button>
                            <Button Style="{StaticResource TitleCloseBtn}"
                                    Click="CloseButton_Click" ToolTip="Close">
                                <TextBlock Text="&#x2715;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Hairline divider -->
                <Border DockPanel.Dock="Top" Height="1" Background="#16FFFFFF"/>

                <!-- Search row -->
                <Border DockPanel.Dock="Top" Padding="12,10,12,6">
                    <Border CornerRadius="12" BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="#24FFFFFF"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#38FFFFFF" Offset="0"/>
                                <GradientStop Color="#12FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid Margin="11,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="13" Height="13"
                                     Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.55">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#FFFFFF"
                                          Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#F5F5F7"
                                     CaretBrush="#FF6A2B"
                                     SelectionBrush="#55F54E00"
                                     FontFamily="Segoe UI"
                                     FontSize="13"
                                     VerticalAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"
                                     PreviewKeyDown="SearchBox_PreviewKeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Grid>
                                                        <TextBlock x:Name="Hint"
                                                                   Text="Search apps..."
                                                                   Foreground="#8E8E93"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="13"
                                                                   IsHitTestVisible="False"
                                                                   Visibility="Visible"/>
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter TargetName="Hint" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button x:Name="ClearButton"
                                    Grid.Column="2"
                                    Content="✕"
                                    Foreground="#8E8E93"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="10"
                                    Cursor="Hand"
                                    Padding="4,0"
                                    Visibility="Collapsed"
                                    Click="ClearSearch_Click"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- Kill button (dock bottom so list fills middle) -->
                <Border DockPanel.Dock="Bottom" Padding="12,6,12,14">
                    <Button x:Name="KillButton"
                            Height="42"
                            FontFamily="Segoe UI"
                            FontSize="14"
                            FontWeight="Medium"
                            Cursor="Hand"
                            IsEnabled="False"
                            Click="KillButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="#8E8E93"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="12" BorderThickness="1">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                        <GradientStop Color="#30FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="True">
                                        <Setter Property="Background" Value="#F54E00"/>
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Force Kill" VerticalAlignment="Center"/>
                            <Border x:Name="EnterHint"
                                    Background="#CC3D0000"
                                    CornerRadius="5"
                                    Padding="6,2"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <TextBlock Text="↵ Enter"
                                           FontFamily="Segoe UI"
                                           FontSize="10"
                                           Foreground="#FFCCC0"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Hairline above kill button -->
                <Border DockPanel.Dock="Bottom" Height="1" Background="#14FFFFFF"/>

                <!-- List + empty state + scroll buttons -->
                <Grid DockPanel.Dock="Top" Margin="0,2,0,0">

                    <TextBlock x:Name="EmptyState"
                               Foreground="#8E8E93"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,32,0,0"
                               Visibility="Collapsed"/>

                    <!-- ListBox (not ListView+GridView) — proper keyboard nav built-in -->
                    <ListBox x:Name="ProcessList"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="8,0,8,4"
                             SelectionMode="Single"
                             VirtualizingPanel.IsVirtualizing="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="ProcessList_SelectionChanged">

                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThinScrollBar}"/>
                        </ListBox.Resources>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                                    CornerRadius="11" Margin="0,1.5">
                                                <ContentPresenter Margin="10,8"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#2BFFFFFF"/>
                                                    <Setter TargetName="Bg" Property="BorderBrush" Value="#45FFFFFF"/>
                                                    <Setter TargetName="Bg" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bg" Property="Background" Value="#14FFFFFF"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="38" Height="38"
                                            CornerRadius="10"
                                            Margin="0,0,12,0"
                                            BorderThickness="1">
                                        <Border.Background>
                                            <SolidColorBrush Color="#1EFFFFFF"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                                <GradientStop Color="#0DFFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Image Source="{Binding IconSource}"
                                               Width="22" Height="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#F5F5F7"
                                                   FontFamily="Segoe UI"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Meta}"
                                                   Foreground="#98989F"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   FontSize="10"
                                                   Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Scroll buttons floating in bottom-right corner -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,16,10" Opacity="0.9">
                        <Button x:Name="ScrollUpBtn"
                                Style="{StaticResource ScrollArrowBtn}"
                                Click="ScrollUpBtn_Click"
                                ToolTip="Scroll up">▲</Button>
                        <Button x:Name="ScrollDownBtn"
                                Style="{StaticResource ScrollArrowBtn}"
                                Margin="0,4,0,0"
                                Click="ScrollDownBtn_Click"
                                ToolTip="Scroll down">▼</Button>
                    </StackPanel>

                </Grid>

            </DockPanel>
        </Border>

        <!-- Hotkey recording overlay — covers all content while listening -->
        <Border x:Name="HotkeyOverlay"
                CornerRadius="18"
                Visibility="Collapsed"
                ClipToBounds="True">
            <Border.Background>
                <SolidColorBrush Color="#E2000000"/>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Press new shortcut"
                           Foreground="#8E8E93"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="HotkeyCapture"
                           Text="—"
                           Foreground="#F5F5F7"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontSize="26"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
                <TextBlock Text="Esc to cancel"
                           Foreground="#3C3C3E"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             Settings popup — floats above everything, separate visual tree
             so GlassSlider style is defined in its own resources.
             ══════════════════════════════════════════════════════════════ -->
        <Popup x:Name="SettingsPopup"
               PlacementTarget="{Binding ElementName=SettingsBtn}"
               Placement="Bottom"
               HorizontalOffset="-246"
               VerticalOffset="4"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Width="288"
                    CornerRadius="14"
                    BorderThickness="1"
                    Padding="18,14,18,16">
                <Border.Resources>
                    <!-- Toggle switch (pill) -->
                    <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
                        <Setter Property="Width" Value="40"/>
                        <Setter Property="Height" Value="22"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Track" CornerRadius="11" Background="#30FFFFFF" BorderThickness="0">
                                        <Border x:Name="Thumb"
                                                Width="18" Height="18" CornerRadius="9"
                                                Background="White"
                                                HorizontalAlignment="Left"
                                                Margin="2,0,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3" Color="#000000"/>
                                            </Border.Effect>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Track" Property="Background" Value="#F54E00"/>
                                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Small text-link button for "Open folder" -->
                    <Style x:Key="LinkBtn" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#8E8E93"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock x:Name="Lbl"
                                               Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               TextDecorations="Underline"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Lbl" Property="Foreground" Value="#C7C7CC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Glass slider with orange filled track -->
                    <Style x:Key="GlassSlider" TargetType="Slider">
                        <Setter Property="Height" Value="20"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Slider">
                                    <Grid Height="20" VerticalAlignment="Center">
                                        <!-- Track rail (unfilled) -->
                                        <Border Height="4" Background="#28FFFFFF" CornerRadius="2" VerticalAlignment="Center"/>
                                        <Track x:Name="PART_Track">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Height="4" Background="#F54E00" CornerRadius="2" VerticalAlignment="Center"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Height="4" Background="Transparent" VerticalAlignment="Center"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Ellipse Width="14" Height="14" Fill="White">
                                                                <Ellipse.Effect>
                                                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.4" Color="#000000"/>
                                                                </Ellipse.Effect>
                                                            </Ellipse>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Border.Resources>
                <Border.Background>
                    <SolidColorBrush Color="#E81C1C1E"/>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                        <GradientStop Color="#12FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="6" Direction="270" Opacity="0.55" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="DISPLAY"
                               Foreground="#636366"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <!-- Width -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Width"
                                   Foreground="#AEAEB2" FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="WidthSlider"
                                Style="{StaticResource GlassSlider}"
                                Minimum="360" Maximum="700" VerticalAlignment="Center"
                                ValueChanged="WidthSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" FontSize="11" Foreground="#C7C7CC"
                                   FontFamily="Segoe UI" HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text="{Binding ElementName=WidthSlider, Path=Value, StringFormat={}{0:0}}"/>
                    </Grid>

                    <!-- Height -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Height"
                                   Foreground="#AEAEB2" FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="HeightSlider"
                                Style="{StaticResource GlassSlider}"
                                Minimum="400" Maximum="780" VerticalAlignment="Center"
                                ValueChanged="HeightSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" FontSize="11" Foreground="#C7C7CC"
                                   FontFamily="Segoe UI" HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text="{Binding ElementName=HeightSlider, Path=Value, StringFormat={}{0:0}}"/>
                    </Grid>

                    <!-- Background opacity -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Opacity"
                                   Foreground="#AEAEB2" FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="OpacitySlider"
                                Style="{StaticResource GlassSlider}"
                                Minimum="0.15" Maximum="1.0" VerticalAlignment="Center"
                                ValueChanged="OpacitySlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" FontSize="11" Foreground="#C7C7CC"
                                   FontFamily="Segoe UI" HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text="{Binding ElementName=OpacitySlider, Path=Value, StringFormat={}{0:0%}}"/>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="#18FFFFFF" Margin="0,0,0,14"/>

                    <!-- STARTUP section header (also covers hotkey) -->
                    <TextBlock Text="STARTUP"
                               Foreground="#636366"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <!-- Hotkey binding -->
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Hotkey"
                                   Foreground="#AEAEB2" FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Background="#1EFFFFFF" CornerRadius="5" Padding="7,3" Margin="0,0,8,0">
                                <TextBlock x:Name="HotkeyBadge"
                                           Text="Ctrl+Alt+Q"
                                           Foreground="#F5F5F7"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="10"/>
                            </Border>
                            <Button Style="{StaticResource LinkBtn}"
                                    Content="Change"
                                    Click="ChangeHotkeyBtn_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Start with Windows toggle -->
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Start with Windows"
                                   Foreground="#AEAEB2"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <ToggleButton x:Name="StartupToggle"
                                      Style="{StaticResource ToggleSwitch}"
                                      HorizontalAlignment="Right"
                                      Click="StartupToggle_Click"/>
                    </Grid>

                    <!-- Open app folder -->
                    <Grid>
                        <TextBlock Text="App location"
                                   Foreground="#AEAEB2"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource LinkBtn}"
                                Content="Open in Explorer →"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="OpenFolderBtn_Click"/>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="#12FFFFFF" Margin="0,14,0,12"/>

                    <!-- Attribution row -->
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Made by"
                                       Foreground="#48484A"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>
                            <Button Style="{StaticResource LinkBtn}"
                                    Content="anshmajumdar121 ↗"
                                    FontSize="11"
                                    Click="AttributionBtn_Click"/>
                        </StackPanel>
                        <!-- Lock icon — shows password-protect info -->
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="4,2"
                                Click="AttributionLock_Click"
                                ToolTip="Password protected">
                            <TextBlock Text="🔒" FontSize="10" Opacity="0.35"/>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</Window>
